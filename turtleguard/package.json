{
  "name": "turtleguard",
  "productName": "TurtleGuard",
  "private": true,
  "version": "0.2.0",
  "description": "A desktop posture monitor that connects camera-based turtle neck detection with Arduino hardware feedback.",
  "author": "jcw050405 <jcw050405@postech.ac.kr>",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "electron:dev": "concurrently \"npm run dev\" \"electron .\"",
    "build:electron": "vite build && electron-builder",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:node": "node --test",
    "test:mvp2": "node --import tsx --test test/postureStandard.test.mjs test/settingsStore.test.mjs test/sessionPayload.test.mjs test/socialClient.test.mjs test/sessionSync.test.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@gsap/react": "^2.1.2",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "gsap": "^3.15.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-use": "^17.6.1",
    "serialport": "^13.0.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/serialport": "^8.0.5",
    "@types/w3c-web-serial": "^1.0.8",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
