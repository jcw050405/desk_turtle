# Copy this file to .env for local Electron development.
# Do not commit real Supabase values.

# Required for profile, group, session sync, and ranking features.
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Optional. Leave empty unless a future public contact form uses Web3Forms.
VITE_WEB3FORMS_ACCESS_KEY=""
